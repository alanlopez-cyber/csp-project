<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Valencia Climate Analysis — v4</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
  :root {
    --navy:    #060d1f;
    --navy2:   #0b1730;
    --navy3:   #0f2044;
    --ocean:   #0a4a7a;
    --blue:    #1e90d4;
    --blue2:   #5bb8f5;
    --orange:  #f97316;
    --orange2: #fdba74;
    --teal:    #06b6d4;
    --red:     #ef4444;
    --green:   #22c55e;
    --text:    #e2eaf8;
    --muted:   #7a93b8;
    --grid:    rgba(30,144,212,0.12);
    --card:    rgba(11,23,48,0.85);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--navy);
    color: var(--text);
    font-family: 'Syne', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 20% 80%, rgba(10,74,122,0.35) 0%, transparent 70%),
      radial-gradient(ellipse 60% 80% at 80% 20%, rgba(6,182,212,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 100% 100% at 50% 50%, rgba(6,13,31,1) 40%, transparent 100%);
    z-index: 0;
    pointer-events: none;
  }
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image: repeating-linear-gradient(
      180deg, transparent, transparent 80px,
      rgba(30,144,212,0.035) 80px, rgba(30,144,212,0.035) 81px
    );
    z-index: 0;
    pointer-events: none;
  }
  .wrapper { position: relative; z-index: 1; max-width: 1300px; margin: 0 auto; padding: 40px 24px 80px; }

  header { text-align: center; padding: 48px 0 56px; }
  .header-badge {
    display: inline-block;
    font-family: 'Space Mono', monospace;
    font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    color: var(--teal);
    border: 1px solid rgba(6,182,212,0.4);
    padding: 6px 18px; border-radius: 20px; margin-bottom: 20px;
    background: rgba(6,182,212,0.07);
    animation: fadeSlideDown 0.8s ease both;
  }
  h1 { font-size: clamp(28px, 5vw, 58px); font-weight: 800; line-height: 1.1; animation: fadeSlideDown 0.9s 0.1s ease both; }
  h1 .hl1 { color: var(--orange); }
  h1 .hl2 { color: var(--blue2); }
  .subtitle { margin-top: 14px; color: var(--muted); font-size: 16px; font-weight: 400; animation: fadeSlideDown 1s 0.2s ease both; }
  .header-line { margin: 32px auto 0; width: 80px; height: 3px; background: linear-gradient(90deg, var(--orange), var(--blue)); border-radius: 2px; animation: expandWidth 1.2s 0.4s ease both; }

  .stat-row { display: flex; justify-content: center; flex-wrap: wrap; gap: 14px; margin-bottom: 52px; animation: fadeSlideUp 1s 0.5s ease both; }
  .stat-pill {
    background: var(--card); border: 1px solid rgba(30,144,212,0.2);
    border-radius: 14px; padding: 16px 24px; text-align: center;
    backdrop-filter: blur(10px); transition: transform 0.2s, border-color 0.2s; min-width: 160px;
  }
  .stat-pill:hover { transform: translateY(-3px); border-color: rgba(30,144,212,0.5); }
  .stat-pill .val { font-size: 26px; font-weight: 800; }
  .stat-pill .val.orange { color: var(--orange); }
  .stat-pill .val.blue   { color: var(--blue2); }
  .stat-pill .val.teal   { color: var(--teal); }
  .stat-pill .val.grey   { color: var(--muted); }
  .stat-pill .lbl { font-size: 11px; color: var(--muted); letter-spacing: 1px; margin-top: 4px; text-transform: uppercase; font-family: 'Space Mono', monospace; }

  .section-label { font-family: 'Space Mono', monospace; font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--muted); margin-bottom: 10px; }
  .section-title  { font-size: 22px; font-weight: 700; margin-bottom: 6px; }
  .section-desc   { font-size: 14px; color: var(--muted); margin-bottom: 24px; font-weight: 400; }

  .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-bottom: 24px; }
  .grid-1 { margin-bottom: 24px; }
  @media (max-width: 860px) { .grid-2 { grid-template-columns: 1fr; } }

  .card {
    background: var(--card); border: 1px solid rgba(30,144,212,0.18);
    border-radius: 20px; padding: 28px; backdrop-filter: blur(12px);
    transition: border-color 0.3s; position: relative; overflow: hidden;
    animation: fadeSlideUp 0.7s ease both;
  }
  .card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, var(--orange), var(--blue)); opacity: 0; transition: opacity 0.3s; }
  .card:hover { border-color: rgba(30,144,212,0.4); }
  .card:hover::before { opacity: 1; }
  .chart-wrap      { position: relative; height: 280px; }
  .chart-wrap-tall { position: relative; height: 340px; }

  .legend { display: flex; gap: 20px; flex-wrap: wrap; margin-bottom: 12px; }
  .legend-item { display: flex; align-items: center; gap: 7px; font-size: 13px; color: var(--muted); }
  .leg-dot  { width: 12px; height: 12px; border-radius: 2px; flex-shrink: 0; }
  .leg-line { width: 20px; height: 3px; border-radius: 2px; flex-shrink: 0; }

  .anomaly-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; margin-top: 8px; }
  @media (max-width: 700px) { .anomaly-grid { grid-template-columns: repeat(2,1fr); } }
  .anomaly-card { border-radius: 14px; padding: 20px 18px; border: 1px solid; transition: transform 0.2s; }
  .anomaly-card:hover { transform: translateY(-4px); }
  .anomaly-card.low  { background: rgba(6,182,212,0.08);  border-color: rgba(6,182,212,0.3);  }
  .anomaly-card.high { background: rgba(249,115,22,0.08); border-color: rgba(249,115,22,0.3); }
  .anomaly-card .year-tag { font-family: 'Space Mono', monospace; font-size: 28px; font-weight: 700; }
  .anomaly-card.low  .year-tag { color: var(--teal); }
  .anomaly-card.high .year-tag { color: var(--orange); }
  .anomaly-card .flag {
    display: inline-block; font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase;
    padding: 3px 10px; border-radius: 8px; margin: 8px 0 6px; font-family: 'Space Mono', monospace;
  }
  .anomaly-card.low  .flag { background: rgba(6,182,212,0.15);  color: var(--teal);    }
  .anomaly-card.high .flag { background: rgba(249,115,22,0.15); color: var(--orange2); }
  .anomaly-card .detail { font-size: 13px; color: var(--muted); line-height: 1.5; }

  .corr-item { margin-bottom: 22px; }
  .corr-item:last-child { margin-bottom: 0; }
  .corr-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
  .corr-label { font-size: 14px; font-weight: 600; }
  .corr-value { font-family: 'Space Mono', monospace; font-size: 15px; }
  .corr-track { height: 10px; background: rgba(255,255,255,0.06); border-radius: 5px; overflow: visible; position: relative; }
  .corr-fill { height: 100%; border-radius: 5px; position: absolute; right: 0; transition: width 1.5s cubic-bezier(0.16,1,0.3,1); }
  .corr-fill.c1 { background: linear-gradient(90deg, var(--blue2), var(--teal)); }
  .corr-fill.c2 { background: linear-gradient(90deg, var(--blue),  var(--blue2)); }
  .corr-fill.c3 { background: linear-gradient(90deg, var(--orange),var(--blue)); }
  .corr-interp { font-size: 12px; color: var(--muted); margin-top: 5px; font-family: 'Space Mono', monospace; }

  footer { text-align: center; padding: 40px 0 20px; color: var(--muted); font-size: 12px; font-family: 'Space Mono', monospace; letter-spacing: 1px; border-top: 1px solid rgba(30,144,212,0.1); margin-top: 60px; }
  footer span { color: var(--blue2); }

  @keyframes fadeSlideDown { from { opacity:0; transform:translateY(-18px); } to { opacity:1; transform:translateY(0); } }
  @keyframes fadeSlideUp   { from { opacity:0; transform:translateY(18px);  } to { opacity:1; transform:translateY(0); } }
  @keyframes expandWidth   { from { width:0; } to { width:80px; } }
</style>
</head>
<body>
<div class="wrapper">

  <header>
    <div class="header-badge">Climate Research &nbsp;·&nbsp; Valencia, Spain</div>
    <h1><span class="hl1">Air Temperature</span> vs<br><span class="hl2">Sea Surface Anomalies</span></h1>
    <p class="subtitle">Mediterranean SST (EEA, 1870–2014) &nbsp;&middot;&nbsp; Valencia RVVCCA August Records (2004–2022)</p>
    <div class="header-line"></div>
  </header>

  <div class="stat-row">
    <div class="stat-pill"><div class="val orange">+1.22°C</div><div class="lbl">Max Air Temp Rise</div></div>
    <div class="stat-pill"><div class="val blue">+0.9416°C</div><div class="lbl">SST Change 1870s→2010s</div></div>
    <div class="stat-pill"><div class="val teal">+7.67</div><div class="lbl">Heatwave Days / Year</div></div>
    <div class="stat-pill"><div class="val grey">−0.3293</div><div class="lbl">Best Pearson r (HW×SST)</div></div>
  </div>

  <!-- ROW 1 -->
  <div class="grid-2">
    <div class="card">
      <div class="section-label">01 · Overlap Period 2004–2014</div>
      <div class="section-title">Max Air Temp vs SST Anomaly</div>
      <div class="section-desc">Orange bars = max August air temperature · Blue line = Mediterranean SST anomaly</div>
      <div class="legend">
        <div class="legend-item"><div class="leg-dot" style="background:var(--orange)"></div> Max Air Temp (°C)</div>
        <div class="legend-item"><div class="leg-line" style="background:var(--blue2)"></div> SST Anomaly (°C)</div>
      </div>
      <div class="chart-wrap"><canvas id="dualChart"></canvas></div>
    </div>

    <div class="card">
      <div class="section-label">02 · Long-Term Trend 1870–2014</div>
      <div class="section-title">Mean SST Anomaly by Decade</div>
      <div class="section-desc">Mediterranean SST averaged per decade — warming trend accelerates from 2000s onward</div>
      <div class="chart-wrap"><canvas id="decadeChart"></canvas></div>
    </div>
  </div>

  <!-- ROW 2 -->
  <div class="grid-2">
    <div class="card">
      <div class="section-label">03 · Statistical Analysis</div>
      <div class="section-title">Pearson Correlation Coefficients</div>
      <div class="section-desc">Air temperature metrics correlated against Mediterranean SST anomaly (n = 11 years)</div>

      <div style="margin-top:24px">
        <div class="corr-item">
          <div class="corr-header">
            <span class="corr-label">Max Air Temp × SST</span>
            <span class="corr-value" style="color:var(--teal)">r = −0.0166</span>
          </div>
          <div class="corr-track"><div class="corr-fill c1" id="cf1" style="width:0%"></div></div>
          <div class="corr-interp">Negligible negative correlation</div>
        </div>
        <div class="corr-item">
          <div class="corr-header">
            <span class="corr-label">Avg Air Temp × SST</span>
            <span class="corr-value" style="color:var(--blue2)">r = −0.2433</span>
          </div>
          <div class="corr-track"><div class="corr-fill c2" id="cf2" style="width:0%"></div></div>
          <div class="corr-interp">Weak negative correlation</div>
        </div>
        <div class="corr-item">
          <div class="corr-header">
            <span class="corr-label">Heatwave Days × SST</span>
            <span class="corr-value" style="color:var(--orange2)">r = −0.3293</span>
          </div>
          <div class="corr-track"><div class="corr-fill c3" id="cf3" style="width:0%"></div></div>
          <div class="corr-interp">Moderate negative correlation — strongest link</div>
        </div>
      </div>

      <div style="margin-top:28px; height:150px; position:relative;">
        <canvas id="corrChart"></canvas>
      </div>
    </div>

    <div class="card">
      <div class="section-label">04 · Anomaly Detection</div>
      <div class="section-title">Flagged Outlier Years</div>
      <div class="section-desc">Years deviating significantly from expected trend during the 2004–2014 overlap window</div>
      <div class="anomaly-grid">
        <div class="anomaly-card low">
          <div class="year-tag">2005</div>
          <div class="flag">SST Low</div>
          <div class="detail">SST anomaly dipped to −0.12°C, bucking the rising trend of adjacent years</div>
        </div>
        <div class="anomaly-card high">
          <div class="year-tag">2010</div>
          <div class="flag">Air High</div>
          <div class="detail">Unusually high August air temps recorded despite continued SST rise (0.34°C)</div>
        </div>
        <div class="anomaly-card high">
          <div class="year-tag">2004</div>
          <div class="flag">HW Days High</div>
          <div class="detail">Peak heatwave count early in the overlap period, post-2003 European heatwave echo</div>
        </div>
        <div class="anomaly-card high">
          <div class="year-tag">2014</div>
          <div class="flag">SST High</div>
          <div class="detail">SST surged to +0.65°C — the highest value in the entire 2004–2014 window</div>
        </div>
      </div>
    </div>
  </div>

  <!-- ROW 3 full-width -->
  <div class="grid-1">
    <div class="card">
      <div class="section-label">05 · Complete Record 1870–2014</div>
      <div class="section-title">Mediterranean SST Anomaly — Full Time Series</div>
      <div class="section-desc">Annual anomaly (°C) relative to pre-industrial baseline · <span style="color:var(--orange)">orange segment</span> = study overlap 2004–2014</div>
      <div class="chart-wrap-tall"><canvas id="fullSSTChart"></canvas></div>
    </div>
  </div>

</div>

<footer>
  <p>Data sources: <span>EEA — Annual Mean Sea Surface Temperature 1870–2014</span> &nbsp;·&nbsp; <span>RVVCCA Valencia August Air Temperature 2004–2022</span></p>
  <p style="margin-top:8px">School Science Report &nbsp;·&nbsp; Climate Analysis Project &nbsp;·&nbsp; Valencia Study v4</p>
</footer>

<script>
// ── DATA ──────────────────────────────────────────────────
const SST_ALL = {
  1870:-0.715031,1871:-0.825611,1872:-0.357485,1873:-0.511297,1874:-0.576514,
  1875:-0.570601,1876:-0.567974,1877:-0.427828,1878:-0.360594,1879:-0.507698,
  1880:-0.500527,1881:-0.448225,1882:-0.691918,1883:-0.780430,1884:-0.815040,
  1885:-0.662349,1886:-0.628157,1887:-0.560420,1888:-0.791674,1889:-0.887050,
  1890:-0.987647,1891:-0.833980,1892:-0.646485,1893:-0.657415,1894:-0.785884,
  1895:-0.625167,1896:-0.869350,1897:-0.659428,1898:-0.774801,1899:-0.590479,
  1900:-0.667080,1901:-0.756213,1902:-0.845867,1903:-1.026189,1904:-0.629129,
  1905:-0.833967,1906:-0.836366,1907:-1.039573,1908:-0.875277,1909:-0.913942,
  1910:-1.080365,1911:-0.688192,1912:-0.972635,1913:-0.769856,1914:-0.977389,
  1915:-0.644123,1916:-0.420927,1917:-0.705052,1918:-0.969568,1919:-0.857966,
  1920:-0.562222,1921:-0.544715,1922:-0.616356,1923:-0.631796,1924:-0.299601,
  1925:-0.702781,1926:-0.412258,1927:-0.165305,1928:-0.188416,1929:-0.690500,
  1930:-0.470161,1931:-0.373814,1932:-0.525485,1933:-0.599187,1934:-0.332704,
  1935:-0.392488,1936:-0.316463,1937: 0.042937,1938:-0.123879,1939:-0.322671,
  1940:-0.664823,1941:-0.526672,1942:-0.441375,1943:-0.351130,1944:-0.384904,
  1945:-0.531112,1946:-0.127308,1947:-0.074538,1948:-0.384177,1949:-0.383410,
  1950: 0.016676,1951:-0.429717,1952:-0.056043,1953:-0.406862,1954:-0.699032,
  1955:-0.158575,1956:-0.693009,1957:-0.511258,1958:-0.410211,1959:-0.476504,
  1960:-0.186919,1961:-0.152392,1962:-0.148273,1963:-0.150978,1964:-0.166850,
  1965:-0.515513,1966:-0.222513,1967:-0.282220,1968:-0.267346,1969:-0.480502,
  1970:-0.493492,1971:-0.575858,1972:-0.868454,1973:-0.621131,1974:-0.817618,
  1975:-0.774273,1976:-0.869584,1977:-0.731220,1978:-1.044848,1979:-0.513308,
  1980:-0.916643,1981:-0.724267,1982:-0.440500,1983:-0.890500,1984:-1.130500,
  1985:-0.630500,1986:-0.490500,1987:-0.710500,1988:-0.510500,1989:-0.520500,
  1990:-0.200500,1991:-0.580500,1992:-0.790500,1993:-0.800500,1994:-0.060500,
  1995:-0.290500,1996:-0.500500,1997:-0.200500,1998:-0.120500,1999: 0.109500,
  2000:-0.080500,2001: 0.069500,2002: 0.049500,2003: 0.439500,2004:-0.050500,
  2005:-0.120500,2006: 0.069500,2007: 0.099500,2008: 0.159500,2009: 0.289500,
  2010: 0.339500,2011: 0.249500,2012: 0.349500,2013: 0.409500,2014: 0.649500
};

const AIR_TEMP = {
  2004:{max:32.8,avg:25.4,hw:18},2005:{max:31.5,avg:24.8,hw:11},
  2006:{max:33.1,avg:25.9,hw:15},2007:{max:32.4,avg:25.2,hw:12},
  2008:{max:31.9,avg:24.7,hw:10},2009:{max:33.5,avg:26.1,hw:14},
  2010:{max:34.2,avg:26.7,hw:16},2011:{max:32.6,avg:25.5,hw:13},
  2012:{max:33.8,avg:26.3,hw:17},2013:{max:33.0,avg:25.8,hw:14},
  2014:{max:32.2,avg:25.0,hw:11}
};

const OVERLAP = [2004,2005,2006,2007,2008,2009,2010,2011,2012,2013,2014];

// ── CHART DEFAULTS ────────────────────────────────────────
Chart.defaults.color = '#7a93b8';
Chart.defaults.font.family = "'Space Mono', monospace";
Chart.defaults.font.size = 11;
const GC = 'rgba(30,144,212,0.1)';
const TC = '#7a93b8';

// ── 1 DUAL-AXIS ───────────────────────────────────────────
new Chart(document.getElementById('dualChart'), {
  data: {
    labels: OVERLAP,
    datasets: [
      {
        type: 'bar',
        label: 'Max Air Temp (°C)',
        data: OVERLAP.map(y => AIR_TEMP[y].max),
        backgroundColor: OVERLAP.map(y => y===2010 ? 'rgba(239,68,68,0.85)' : 'rgba(249,115,22,0.72)'),
        borderColor:     OVERLAP.map(y => y===2010 ? '#ef4444' : '#f97316'),
        borderWidth: 2, borderRadius: 5, yAxisID: 'y', order: 2
      },
      {
        type: 'line',
        label: 'SST Anomaly (°C)',
        data: OVERLAP.map(y => SST_ALL[y]),
        borderColor: '#5bb8f5',
        backgroundColor: 'rgba(91,184,245,0.1)',
        borderWidth: 2.5,
        pointBackgroundColor: OVERLAP.map(y => y===2005?'#06b6d4': y===2014?'#f97316':'#5bb8f5'),
        pointRadius: 5, pointHoverRadius: 8,
        fill: true, tension: 0.4, yAxisID: 'y2', order: 1
      }
    ]
  },
  options: {
    responsive:true, maintainAspectRatio:false,
    interaction:{mode:'index',intersect:false},
    plugins:{
      legend:{display:false},
      tooltip:{
        backgroundColor:'rgba(6,13,31,0.95)',
        borderColor:'rgba(30,144,212,0.4)', borderWidth:1,
        titleColor:'#e2eaf8', bodyColor:'#7a93b8', padding:12,
        callbacks:{
          title: c => `Year: ${c[0].label}`,
          beforeBody: c => {
            const yr = parseInt(c[0].label), d = AIR_TEMP[yr];
            return [`Max Temp:  ${d.max}°C`,`Avg Temp:  ${d.avg}°C`,
                    `HW Days:   ${d.hw}`,`SST Anom:  ${SST_ALL[yr].toFixed(4)}°C`];
          },
          label: () => null
        }
      }
    },
    scales:{
      x:{grid:{color:GC},ticks:{color:TC}},
      y:{position:'left',grid:{color:GC},ticks:{color:'#f97316',callback:v=>v+'°C'},
         title:{display:true,text:'Max Air Temp (°C)',color:'#f97316'},min:29,max:36},
      y2:{position:'right',grid:{drawOnChartArea:false},ticks:{color:'#5bb8f5',callback:v=>v.toFixed(2)},
          title:{display:true,text:'SST Anomaly (°C)',color:'#5bb8f5'},min:-0.3,max:0.8}
    }
  }
});

// ── 2 DECADE MEANS ────────────────────────────────────────
const decadeStarts = [1870,1880,1890,1900,1910,1920,1930,1940,1950,1960,1970,1980,1990,2000,2010];
const decadeLabels = decadeStarts.map(d => d+'s');
const decadeMeans  = decadeStarts.map(s => {
  const vals = [];
  for (let y=s; y<=s+9; y++) if (SST_ALL[y]!==undefined) vals.push(SST_ALL[y]);
  return vals.length ? vals.reduce((a,b)=>a+b,0)/vals.length : null;
});

new Chart(document.getElementById('decadeChart'), {
  type:'bar',
  data:{
    labels: decadeLabels,
    datasets:[{
      label:'Mean SST Anomaly',
      data: decadeMeans,
      backgroundColor: decadeMeans.map(v => v>0 ? 'rgba(249,115,22,0.75)' : `rgba(30,144,212,${Math.min(0.85,0.35+Math.abs(v)*0.5)})`),
      borderColor:     decadeMeans.map(v => v>0 ? '#f97316' : '#1e90d4'),
      borderWidth:1.5, borderRadius:4
    }]
  },
  options:{
    responsive:true, maintainAspectRatio:false,
    plugins:{
      legend:{display:false},
      tooltip:{
        backgroundColor:'rgba(6,13,31,0.95)',borderColor:'rgba(30,144,212,0.3)',borderWidth:1,
        callbacks:{label: c => ` ${c.parsed.y.toFixed(4)}°C anomaly`}
      }
    },
    scales:{
      x:{grid:{color:GC},ticks:{color:TC,maxRotation:45,minRotation:30,font:{size:10}}},
      y:{grid:{color:GC},ticks:{color:TC,callback:v=>v.toFixed(2)},
         title:{display:true,text:'SST Anomaly (°C)',color:'#5bb8f5'}}
    }
  }
});

// ── 3 CORRELATION BARS ────────────────────────────────────
new Chart(document.getElementById('corrChart'), {
  type:'bar',
  data:{
    labels:['Max Temp × SST','Avg Temp × SST','HW Days × SST'],
    datasets:[{
      data:[-0.0166,-0.2433,-0.3293],
      backgroundColor:['rgba(6,182,212,0.6)','rgba(30,144,212,0.7)','rgba(249,115,22,0.7)'],
      borderColor:['#06b6d4','#1e90d4','#f97316'],
      borderWidth:1.5, borderRadius:4
    }]
  },
  options:{
    indexAxis:'y', responsive:true, maintainAspectRatio:false,
    plugins:{
      legend:{display:false},
      tooltip:{
        backgroundColor:'rgba(6,13,31,0.95)',borderColor:'rgba(30,144,212,0.3)',borderWidth:1,
        callbacks:{label: c => ` r = ${c.parsed.x.toFixed(4)}`}
      }
    },
    scales:{
      x:{grid:{color:GC},ticks:{color:TC},min:-0.45,max:0,title:{display:true,text:'Pearson r',color:TC}},
      y:{grid:{color:'transparent'},ticks:{color:TC}}
    }
  }
});

// ── 5 FULL TIME SERIES ────────────────────────────────────
const allYears = Object.keys(SST_ALL).map(Number);
const allSST   = allYears.map(y => SST_ALL[y]);

const fullCtx  = document.getElementById('fullSSTChart').getContext('2d');
const grad = fullCtx.createLinearGradient(0,0,0,340);
grad.addColorStop(0,'rgba(30,144,212,0.25)');
grad.addColorStop(1,'rgba(30,144,212,0.01)');

new Chart(fullCtx, {
  type:'line',
  data:{
    labels: allYears,
    datasets:[
      {
        label:'SST Anomaly',
        data: allSST,
        borderColor:'#1e90d4', backgroundColor:grad,
        borderWidth:1.8, pointRadius:0, pointHoverRadius:5,
        fill:true, tension:0.35
      },
      {
        label:'Overlap Study Period (2004–2014)',
        data: allYears.map(y => (y>=2004&&y<=2014) ? SST_ALL[y] : null),
        borderColor:'#f97316', backgroundColor:'transparent',
        borderWidth:3.5, pointRadius:0, pointHoverRadius:6,
        fill:false, tension:0.35, spanGaps:false
      }
    ]
  },
  options:{
    responsive:true, maintainAspectRatio:false,
    animation:{duration:2000, easing:'easeInOutQuart'},
    plugins:{
      legend:{display:true,labels:{color:TC,usePointStyle:true,font:{size:11}}},
      tooltip:{
        backgroundColor:'rgba(6,13,31,0.95)',borderColor:'rgba(30,144,212,0.3)',borderWidth:1,
        mode:'index', intersect:false,
        callbacks:{label: c => c.parsed.y===null ? null : ` ${c.dataset.label}: ${c.parsed.y.toFixed(4)}°C`}
      }
    },
    scales:{
      x:{
        grid:{color:GC},
        ticks:{color:TC, maxTicksLimit:16, callback:(v,i) => allYears[i]%10===0 ? allYears[i] : ''}
      },
      y:{
        grid:{color:GC},
        ticks:{color:TC, callback:v=>v.toFixed(2)},
        title:{display:true,text:'SST Anomaly (°C)',color:'#5bb8f5'}
      }
    }
  }
});

// ── CSS CORRELATION BAR ANIMATION ─────────────────────────
const io = new IntersectionObserver(entries => {
  if (!entries[0].isIntersecting) return;
  setTimeout(() => {
    document.getElementById('cf1').style.width = (0.0166/0.5*100)+'%';
    document.getElementById('cf2').style.width = (0.2433/0.5*100)+'%';
    document.getElementById('cf3').style.width = (0.3293/0.5*100)+'%';
  }, 400);
  io.disconnect();
}, {threshold:0.3});
io.observe(document.querySelector('.corr-item'));
</script>
</body>
</html>
